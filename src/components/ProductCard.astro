---
import type { Product } from "../content/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<a class={`card product-card tone-${product.accent}`} href={`/${product.slug}/`}>
  <span class="product-icon">{product.letter}</span>
  <h3>{product.name} · {product.latinName}</h3>
  <p class="body-copy">{product.homepageSummary}</p>
  <span class="tone-text" aria-label={`Open ${product.name}`}>{product.primaryCta} -></span>
</a>
