---
import type { Product } from "../content/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<figure class={`product-visual visual-${product.image.variant} tone-${product.accent}`}>
  <img src={product.image.src} alt={product.image.alt} loading="eager" decoding="async" />
</figure>
